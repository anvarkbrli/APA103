@using _27_FrontToBackSqlConnection.ViewModels.Account
@model RegisterVM

<main class="main-content">
    <div class="breadcrumb-area breadcrumb-height"
         data-bg-image="assets/images/breadcrumb/bg/1-1-1919x388.jpg">
        <div class="container h-100">
            <div class="row h-100">
                <div class="col-lg-12">
                    <div class="breadcrumb-item">
                        <h2 class="breadcrumb-heading">Login & Register Page</h2>
                        <ul>
                            <li>
                                <a href="index.html">Home</a>
                            </li>
                            <li>Register</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="login-register-area section-space-y-axis-100">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-6 pt-5 pt-lg-0">
                    <form action="" method="post">
                        <div class="login-form">
                            <h4 class="login-title">Register</h4>
                            <div class="row">
                                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                                <div class="col-md-6 col-12">
                                    <label>Name</label>
                                    <input asp-for="Name" placeholder="Please Enter Your Name" />
                                    <span asp-validation-for="Name" style="color:red"></span>
                                </div>
                                <div class="col-md-6 col-12">
                                    <label>Surname</label>
                                    <input asp-for="Surname" placeholder="Please Enter Your Surnaame" />
                                    <span asp-validation-for="Surname" style="color:red"></span>
                                </div>
                                <div class="col-md-12">
                                    <label>Username</label>
                                    <input asp-for="Username" placeholder="Please Enter a Username" />
                                    <span asp-validation-for="Username" style="color:red"></span>
                                </div>
                                <div class="col-md-12">
                                    <label>Email Address*</label>
                                    <input asp-for="Email" placeholder="Please Enter Your Email Address" />
                                    <span asp-validation-for="Email" style="color:red"></span>
                                </div>
                                <div class="col-md-6">
                                    <label>Password</label>
                                    <input asp-for="Password" placeholder="Please enter a password" />
                                    <span asp-validation-for="Password" style="color:red"></span>
                                </div>
                                <div class="col-md-6">
                                    <label>Confirm Password</label>
                                    <input asp-for="ConfirmPassword" placeholder="Enter password again" />
                                    <span asp-validation-for="ConfirmPassword" style="color:red"></span>
                                </div>
                                <div class="col-12">
                                    <button class="btn btn-custom-size lg-size btn-pronia-primary">
                                        Register
                                    </button>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</main>
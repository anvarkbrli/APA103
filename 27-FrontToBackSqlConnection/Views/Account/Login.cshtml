@using _27_FrontToBackSqlConnection.ViewModels.Account
@model LoginVM

<main class="main-content">
    <div class="breadcrumb-area breadcrumb-height"
         data-bg-image="assets/images/breadcrumb/bg/1-1-1919x388.jpg">
        <div class="container h-100">
            <div class="row h-100">
                <div class="col-lg-12">
                    <div class="breadcrumb-item">
                        <h2 class="breadcrumb-heading">Login & Register Page</h2>
                        <ul>
                            <li>
                                <a href="index.html">Home</a>
                            </li>
                            <li>Register</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="login-register-area section-space-y-axis-100">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-6 pt-5 pt-lg-0">
                    <form action="" method="post">
                        <div class="login-form">
                            <h4 class="login-title">Register</h4>
                            <div class="row">
                                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                                <div class="col-md-12">
                                    <label for="UsernameOrEmail">Username or Email</label>
                                    <input asp-for="UsernameOrEmail" placeholder="Enter Username or Email" />
                                    <span asp-validation-for="UsernameOrEmail" style="color:red"></span>
                                </div>
                                <div class="col-md-12">
                                    <label for="Password">Password</label>
                                    <input asp-for="Password" placeholder="Please Enter Your Surnaame" />
                                    <span asp-validation-for="Password" style="color:red"></span>
                                </div>
                                <div class="col-md-12 d-flex gap-2">
                                    <label for="IsPersistent">Remember me</label>
                                    <input asp-for="IsPersistent" placeholder="Please Enter a Username" />
                                    <span asp-validation-for="IsPersistent" style="color:red"></span>
                                </div>
                                
                                <div class="col-12">
                                    <button class="btn btn-custom-size lg-size btn-pronia-primary">
                                        Login
                                    </button>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</main>